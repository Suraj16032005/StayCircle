<% layout("/layouts/boilerplate") %>

<div class="container mt-4">
    <!-- Header & Tabs -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="font-weight-bold mb-1">Recommendations</h2>
            <p class="text-muted">Discover stays recommended directly to you by your trusted circle.</p>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-pills mb-4 bg-light p-1 rounded-pill" style="max-width: fit-content;">
        <li class="nav-item">
            <a class="nav-link active rounded-pill px-4" href="/recommendations">
                <i class="fa-solid fa-envelope-open me-2"></i>Recommended For You
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link rounded-pill px-4" href="/recommendations/sent">
                <i class="fa-solid fa-paper-plane me-2"></i>Sent Recommendations
            </a>
        </li>
    </ul>

    <!-- Filter Alert -->
    <% if (filteredFriend) { %>
        <div class="alert alert-info border-0 rounded-4 shadow-sm d-flex justify-content-between align-items-center mb-4 py-3 px-4">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-filter me-3 fs-5 text-info"></i>
                <span>Showing recommendations only from <strong><%= filteredFriend.name || filteredFriend.username %></strong> (@<%= filteredFriend.username %>)</span>
            </div>
            <a href="/recommendations" class="btn btn-sm btn-dark rounded-pill px-3">Clear Filter</a>
        </div>
    <% } %>

    <!-- Recommendations Grid -->
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">
        <% let validRecs = recommendations.filter(rec => rec.listing); %>
        <% if (validRecs.length === 0) { %>
            <div class="col-12 text-center py-5 my-5">
                <div class="mb-4" style="font-size: 4rem; color: #cbd5e0;">
                    <i class="fa-solid fa-heart-broken"></i>
                </div>
                <h4 class="font-weight-bold text-secondary">No recommendations found</h4>
                <p class="text-muted">
                    <% if (filteredFriend) { %>
                        <%= filteredFriend.name || filteredFriend.username %> has not recommended any stays to you yet.
                    <% } else { %>
                        Your friends haven't recommended any places to you yet.
                    <% } %>
                </p>
                <a href="/listings" class="btn btn-dark mt-3 px-4 rounded-pill">Explore Listings</a>
            </div>
        <% } else { %>
            <% for (let rec of validRecs) { %>
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative hover-lift transition">
                        <!-- Sender Badge -->
                        <div class="position-absolute top-0 start-0 m-3 z-3">
                            <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm">
                                <i class="fa-solid fa-user me-1"></i><%= rec.recommendedBy.name || rec.recommendedBy.username %>
                            </span>
                        </div>
                        
                        <img src="<%= rec.listing.image.url %>" class="card-img-top" alt="<%= rec.listing.title %>" style="height: 14rem; object-fit: cover;">
                        
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title font-weight-bold mb-1 text-dark"><%= rec.listing.title %></h5>
                            <p class="card-text text-muted mb-3" style="font-size: 0.85rem;">
                                <i class="fa-solid fa-location-dot me-1 text-secondary"></i><%= rec.listing.location %>, <%= rec.listing.country %>
                            </p>
                            
                            <!-- Note Section -->
                            <div class="p-3 bg-light rounded-3 mb-4 flex-grow-1" style="border-left: 4px solid #fe424d;">
                                <small class="text-muted d-block mb-1 font-weight-bold">Note:</small>
                                <p class="card-text mb-0 italic" style="font-size: 0.9rem; line-height: 1.5; color: #4a5568;">
                                    "<%= rec.message || 'No note attached.' %>"
                                </p>
                            </div>
                            
                            <a href="/listings/<%= rec.listing._id %>" class="btn btn-dark w-100 rounded-pill py-2">
                                <i class="fa-solid fa-circle-info me-1"></i>View Listing
                            </a>
                        </div>
                    </div>
                </div>
            <% } %>
        <% } %>
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    }
    .transition {
        transition: all 0.3s ease;
    }
    .italic {
        font-style: italic;
    }
</style>
