<% layout("/layouts/boilerplate") %>

    <div class="row mt-3" data-listing-id-show="<%= individualListing._id %>">
        <div class="col-8 offset-3">
            <h2 class="mb-1 font-weight-bold">
                <%=individualListing.title%>
            </h2>
            <div class="d-flex align-items-center gap-2 mb-3 mt-1">
                <% if (avgRating > 0) { %>
                    <span class="text-warning" style="font-size: 0.9rem;">
                        <% for(let i = 1; i <= 5; i++) { %>
                            <i class="fa-<%= i <= Math.round(avgRating) ? 'solid' : 'regular' %> fa-star"></i>
                        <% } %>
                    </span>
                    <span class="text-muted" style="font-size: 0.85rem;">(<%= individualListing.reviews.length %> <%= individualListing.reviews.length === 1 ? 'review' : 'reviews' %>)</span>
                <% } %>
                <span class="badge bg-success rounded-pill px-3 py-1.5" style="font-size: 0.85rem;" id="trust-score-badge">
                    <i class="fa-solid fa-heart me-1"></i> Trust Score: <span id="trust-score-val"><%= trustScore %></span> Trusted Recommendations
                </span>
            </div>
        </div>
        <div class="card col-6 offset-3 show-card">
            <div class="show-image-container">
                <img src="<%=individualListing.image.url%>" class="card-img-top show-image" alt="listing_image">
            </div>
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="owner-avatar me-3">
                        <i class="fa-solid fa-circle-user" style="font-size: 2.5rem; color: #a0aec0;"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">Hosted by</small>
                        <h6 class="mb-0 font-weight-bold"><%= individualListing.owner.username %></h6>
                    </div>
                </div>

                <hr class="my-3">

                <h5 class="font-weight-bold mb-3">About this place</h5>
                <p class="card-text text-muted mb-4" style="line-height: 1.6; font-size: 1rem;">
                    <%=individualListing.description%>
                </p>

                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-4 d-flex align-items-center">
                            <i class="fa-solid fa-location-dot me-3 text-secondary" style="font-size: 1.25rem;"></i>
                            <div>
                                <small class="text-muted d-block">Location</small>
                                <strong><%=individualListing.location%></strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-4 d-flex align-items-center">
                            <i class="fa-solid fa-globe me-3 text-secondary" style="font-size: 1.25rem;"></i>
                            <div>
                                <small class="text-muted d-block">Country</small>
                                <strong><%=individualListing.country%></strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-3 bg-light rounded-4 d-flex align-items-center justify-content-between mb-2">
                    <div class="d-flex align-items-center">
                        <i class="fa-solid fa-tag me-3 text-secondary" style="font-size: 1.25rem;"></i>
                        <strong>Price per night</strong>
                    </div>
                    <span class="fs-4 font-weight-bold" style="color: #fe424d;">
                        &#8377;<%=individualListing.price.toLocaleString("en-IN") %>
                    </span>
                </div>
            </div>
        </div>
        <div class="col-6 offset-3 mb-4 d-flex gap-2 align-items-center flex-wrap">
            <% if(currUser && individualListing.owner._id.equals(currUser._id)){ %>
                <a href="/listings/edit/<%=individualListing._id%>"
                    class="btn btn-dark btn-edit-listing px-4">Edit</a>
                <form method="post" action="/listings/<%=individualListing._id%>?_method=DELETE" class="m-0">
                    <button class="btn btn-dark btn-delete-listing px-4">Delete</button>
                </form>
            <% } %>
            <% if(currUser) { %>
                <button type="button" class="btn btn-success btn-recommend px-4" data-bs-toggle="modal" data-bs-target="#recommendModal" style="background-color: #fe424d !important; border: none !important;">
                    <i class="fa-solid fa-paper-plane me-2"></i>Recommend
                </button>
            <% } %>
            <a href="/listings" class="btn btn-back-listing px-4">Back</a>
        </div>


                    <div class="col-8 offset-3 mt-3 mb-3">
                        <hr>
                        <h4>Leave A Review</h4>
                        <form action="/listings/<%=individualListing._id%>/reviews" method="POST" novalidate
                            class="needs-validation">
                            <!-- <div>
                                <label for="rating" class="form-label">Rating</label>
                                <input type="range" min="1" max="5" id="rating" name="review[rating]"
                                    class="form-range">
                            </div> -->

                            <fieldset class="starability-slot">
                                <legend>Rate:</legend>
                                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1"
                                    checked aria-label="No rating." />
                                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                <label for="first-rate1" title="Terrible">1 star</label>
                                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                <label for="first-rate2" title="Not good">2 stars</label>
                                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                <label for="first-rate3" title="Average">3 stars</label>
                                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                <label for="first-rate4" title="Very good">4 stars</label>
                                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                <label for="first-rate5" title="Amazing">5 stars</label>
                            </fieldset>

                            <div>
                               <p></p>
                            </div>

                            <div>
                                <label for="comment" class="form-label">Comments</label>
                                <textarea name="review[comment]" id="comment" cols="30" rows="5"
                                    class="form-control" required></textarea>
                                <div class="invalid-feedback">Please add some reviews</div>
                            </div>

                            <button class="btn btn-outline-dark mt-3 mb-3">Submit</button>
                        </form>
                        <hr>

                                <p><b>All Reviews</b></p>
                                <div class="row">
                                    <%for(review of individualListing.reviews){ %>
                                        <div class="card col-5 ms-3 mb-3 review-card">
                                            <div class="card-body">
                                                <h5 class="card-title">
                                                    @<%=review.author.username%>
                                                </h5>
                                                <p class="starability-result" data-rating='<%=review.rating%>'></p>
                                                <p class="card-text">
                                                    <%=review.comment%>
                                                </p>
                                                <p class="card-text">stars:<%=review.rating%> 
                                                </p>
                                                <% if(currUser && review.author._id.equals(currUser._id)){ %>
                                                <form class="mb-3"
                                                    action="/listings/<%=individualListing._id%>/reviews/<%=review._id%>?_method=DELETE"
                                                    method="POST">
                                                    <button class="btn btn-sm btn-dark">Delete</button>
                                                </form>
                                                <% } %>

                                            </div>
                                        </div>
                                        <%} %>
                                </div>


                    </div>

        </div>

    </div>

    <!-- Recommend Modal -->
    <% if (currUser) { %>
        <div class="modal fade" id="recommendModal" tabindex="-1" aria-labelledby="recommendModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content rounded-4 border-0 shadow">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title font-weight-bold" id="recommendModalLabel">Recommend "<%= individualListing.title %>"</h5>
                        <button type="button" class="btn-close" data-bs-close="modal" aria-label="Close"></button>
                    </div>
                    <form action="/recommendations" method="POST">
                        <div class="modal-body py-4">
                            <input type="hidden" name="listingId" value="<%= individualListing._id %>">
                            
                            <% if (friends && friends.length > 0) { %>
                                <div class="mb-3">
                                    <label for="friendId" class="form-label font-weight-bold">Select Friend</label>
                                    <select class="form-select rounded-3" id="friendId" name="friendId" required>
                                        <option value="" disabled selected>Choose a friend...</option>
                                        <% for (let friend of friends) { %>
                                            <option value="<%= friend._id %>"><%= friend.name || friend.username %> (@<%= friend.username %>)</option>
                                        <% } %>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label for="message" class="form-label font-weight-bold">Optional Note</label>
                                    <textarea class="form-control rounded-3" id="message" name="message" rows="3" placeholder="e.g., Great location near the beach!"></textarea>
                                </div>
                            <% } else { %>
                                <div class="text-center py-3">
                                    <div class="mb-3 text-muted" style="font-size: 3rem;">
                                        <i class="fa-solid fa-user-group"></i>
                                    </div>
                                    <p class="text-muted">You need to connect with friends first to make recommendations.</p>
                                    <a href="/friends" class="btn btn-sm btn-dark rounded-pill px-3">Go to Friends</a>
                                </div>
                            <% } %>
                        </div>
                        <div class="modal-footer border-0 pt-0">
                            <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                            <% if (friends && friends.length > 0) { %>
                                <button type="submit" class="btn btn-danger rounded-pill px-4" style="background-color: #fe424d; border: none;">Submit</button>
                            <% } %>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    <% } %>