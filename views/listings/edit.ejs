<% layout("/layouts/boilerplate") %>

  <div class="row justify-content-center mt-4">
    <div class="col-lg-8">
      <div class="auth-card mb-5">
        <h3 class="mb-4 font-weight-bold">Edit Listing Details</h3>
        <form method="post" action="/listings/<%=EditList._id%>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">

          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" name="listing[title]" value="<%=EditList.title%>" class="form-control" required>
            <div class="invalid-feedback">Title is required.</div>
          </div>

          <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control" rows="4" required><%=EditList.description%></textarea>
            <div class="invalid-feedback">Description cannot be empty.</div>
          </div>

          <div class="mb-3">
            <label class="form-label">Current Listing Image</label>
            <div class="mb-2">
              <img src="<%=originalUrl%>" class="rounded border shadow-sm" style="max-height: 150px; object-fit: cover;">
            </div>
            <label for="image" class="form-label">Upload New Image Link</label>
            <input type="file" name="listing[image]" class="form-control">
          </div>

          <div class="row">
            <div class="mb-3 col-md-4">
              <label for="price" class="form-label">Price</label>
              <input type="number" name="listing[price]" value="<%=EditList.price%>" class="form-control" required>
              <div class="invalid-feedback">Price cannot be empty.</div>
            </div>

            <div class="mb-3 col-md-8">
              <label for="country" class="form-label">Country</label>
              <input type="text" name="listing[country]" value="<%=EditList.country%>" class="form-control" required>
              <div class="invalid-feedback">Country needs to be mentioned.</div>
            </div>
          </div>

          <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input type="text" name="listing[location]" value="<%=EditList.location%>" class="form-control" required>
            <div class="invalid-feedback">Location cannot be empty.</div>
          </div>

          <button class="btn btn-dark edit-btn w-100 mt-3">Update Listing</button>
        </form>
      </div>
    </div>
  </div>