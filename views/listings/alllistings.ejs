<% layout("/layouts/boilerplate") %>
   
<body>
  <div class="listings-header mt-4 mb-4">
    <% if (locals.country) { %>
      <h2 class="font-weight-bold">Stays in <%= locals.country %></h2>
      <p class="text-muted">Explore properties listed in <%= locals.country %>.</p>
    <% } else { %>
      <h2 class="font-weight-bold">Explore Extraordinary Stays</h2>
      <p class="text-muted">Find the perfect place to stay, play, or unwind around the world.</p>
    <% } %>
  </div>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% if (alllistings.length === 0) { %>
      <div class="col-12 text-center my-5 py-5">
        <div class="mb-4" style="font-size: 4rem; color: #cbd5e0;">
          <i class="fa-solid fa-map-location-dot"></i>
        </div>
        <h3 class="font-weight-bold" style="color: #4a5568;">No such listings exist</h3>
        <p class="text-muted">We couldn't find any stays in "<%= locals.country %>". Try searching for another country or browse all properties.</p>
        <a href="/listings" class="btn btn-dark mt-3 px-4 btn-edit-listing">View All Listings</a>
      </div>
    <% } else { %>
      <% for(listing of alllistings){ %>
        <a href="/listings/<%=listing._id%>" class="listing-link">
          <div class="card col listing-card position-relative">
            <% if (maxTrustScore > 0 && listing.trustScore === maxTrustScore) { %>
              <span class="badge bg-danger position-absolute top-0 end-0 m-3 shadow-sm rounded-pill px-3 py-2" style="background-color: #fe424d !important; font-size: 0.75rem; z-index: 10;">
                <i class="fa-solid fa-fire me-1"></i>Most Recommended
              </span>
            <% } %>
            <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_img" style="height:20rem">
            <div class="card-body">
              <p class="card-text mb-1"><b>
                  <%= listing.title %>
                </b>
              </p>
              <p class="card-text text-muted mb-1" style="font-size: 0.85rem;">
                <i class="fa-solid fa-location-dot me-1" style="color: #a0aec0;"></i><%= listing.location %>, <%= listing.country %>
              </p>
              <% if (listing.trustScore > 0) { %>
                <p class="card-text text-success mb-1" style="font-size: 0.85rem; font-weight: 600; color: #10b981 !important;">
                  <i class="fa-solid fa-heart me-1" style="color: #fe424d;"></i><%= listing.trustScore %> Trusted <%= listing.trustScore === 1 ? 'Recommendation' : 'Recommendations' %>
                </p>
              <% } %>
              <p class="card-text">
                <span class="price-tag">&#8377;<%= listing.price.toLocaleString("en-IN") %></span> <span style="font-size: 0.85rem; color: #718096;">/ night</span>
              </p>
            </div>
          </div>
        </a>
      <% } %>
    <% } %>
  </div>
</body>